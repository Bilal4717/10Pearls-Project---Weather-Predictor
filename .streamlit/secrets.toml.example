# Copy this file to .streamlit/secrets.toml for LOCAL Streamlit runs,
# or paste these keys into the Streamlit Cloud "Secrets" settings box.
# Do NOT commit the real secrets.toml.

AQICN_TOKEN = "your_aqicn_token"
HOPSWORKS_API_KEY = "your_hopsworks_api_key"

